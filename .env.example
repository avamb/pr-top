# PsyLink Environment Configuration
# Copy this file to .env and fill in the values

# === Security (REQUIRED - change these in production!) ===
JWT_SECRET=change-me-to-a-random-64-char-string
ENCRYPTION_MASTER_KEY=change-me-to-a-random-64-char-string
BOT_API_KEY=change-me-to-a-random-api-key

# === Superadmin Credentials ===
SUPERADMIN_EMAIL=admin@psylink.app
SUPERADMIN_PASSWORD=ChangeThisPassword123!

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather

# === Stripe Payments (optional - leave empty to disable) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === AI / Transcription (optional) ===
# Provider selection (default: openai)
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini

# OpenAI (default provider)
AI_API_KEY=
# AI_API_URL=https://api.openai.com/v1  # custom endpoint (optional)

# Anthropic (optional — set key to use Claude models)
ANTHROPIC_API_KEY=
# ANTHROPIC_API_URL=https://api.anthropic.com/v1  # custom endpoint (optional)
# To use: set AI_PROVIDER=anthropic, AI_MODEL=claude-3-haiku or claude-3.5-sonnet

# Google Gemini (optional — set key to use Gemini models)
GOOGLE_AI_API_KEY=
# To use: set AI_PROVIDER=google, AI_MODEL=gemini-1.5-flash or gemini-1.5-pro

# OpenRouter (optional — unified API for any model)
OPENROUTER_API_KEY=
# To use: set AI_PROVIDER=openrouter, AI_MODEL=deepseek/deepseek-chat or any slug

# Transcription
TRANSCRIPTION_PROVIDER=openai
TRANSCRIPTION_MODEL=whisper-1
TRANSCRIPTION_API_KEY=
# TRANSCRIPTION_API_URL=https://api.openai.com/v1  # custom endpoint (optional)
# TRANSCRIPTION_LANGUAGE=  # auto-detect if empty

# === Email / SMTP (optional - leave empty to disable, emails logged to console) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PR-TOP <noreply@prtop.app>

# === Scheduler (optional) ===
SCHEDULER_ENABLED=true

# === Backups (optional) ===
BACKUP_DIR=./backups
BACKUP_RETENTION_COUNT=30
BACKUP_CRON=0 3 * * *

# === Umami Web Analytics (optional - privacy-first, cookieless, GDPR-compliant) ===
# Umami tracks landing page visitors, conversions, and traffic sources.
# After first launch, log in to Umami dashboard, create a website, and paste the website ID below.
UMAMI_WEBSITE_ID=
# Umami dashboard URL (used for SuperAdmin link; set to your domain in production)
UMAMI_DASHBOARD_URL=http://localhost:3000
# Umami database credentials (for Docker Compose)
UMAMI_DATABASE_URL=postgresql://umami:umami@umami-db:5432/umami
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=umami
UMAMI_APP_SECRET=replace-me-with-a-random-string
# Default Umami admin credentials (change after first login!)
# UMAMI_ADMIN_USER=admin
# UMAMI_ADMIN_PASSWORD=umami

# === Logging ===
LOG_LEVEL=info
