# PsyLink Environment Configuration
# Copy this file to .env and fill in the values

# === Security (REQUIRED - change these in production!) ===
JWT_SECRET=change-me-to-a-random-64-char-string
ENCRYPTION_MASTER_KEY=change-me-to-a-random-64-char-string
BOT_API_KEY=change-me-to-a-random-api-key

# === Superadmin Credentials ===
SUPERADMIN_EMAIL=admin@psylink.app
SUPERADMIN_PASSWORD=ChangeThisPassword123!

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather

# === Stripe Payments (optional - leave empty to disable) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === AI / Transcription (optional) ===
# OpenAI (default provider)
AI_API_KEY=
AI_MODEL=gpt-4o-mini
# AI_PROVIDER=openai  # auto-detected from model name

# Anthropic (set key + model to use Claude)
ANTHROPIC_API_KEY=
# AI_MODEL=claude-3-haiku  # or claude-3.5-sonnet

# Google Gemini (set key + model to use Gemini)
GOOGLE_AI_API_KEY=
# AI_MODEL=gemini-1.5-flash  # or gemini-1.5-pro

# OpenRouter (unified API for any model including Chinese models)
OPENROUTER_API_KEY=
# AI_MODEL=deepseek/deepseek-chat  # or any OpenRouter model slug

# Transcription
TRANSCRIPTION_API_KEY=

# === Email / SMTP (optional - leave empty to disable, emails logged to console) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PR-TOP <noreply@prtop.app>

# === Scheduler (optional) ===
SCHEDULER_ENABLED=true

# === Backups (optional) ===
BACKUP_DIR=./backups
BACKUP_RETENTION_COUNT=30
BACKUP_CRON=0 3 * * *

# === Logging ===
LOG_LEVEL=info
